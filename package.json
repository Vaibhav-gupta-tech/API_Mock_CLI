{
  "name": "apimock",
  "version": "1.0.0",
  "description": "Instant API Mocking CLI — spin up a mock HTTP server from an OpenAPI spec in seconds",
  "main": "dist/index.js",
  "bin": {
    "apimock": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "keywords": [
    "api",
    "mock",
    "openapi",
    "cli",
    "http",
    "server",
    "testing"
