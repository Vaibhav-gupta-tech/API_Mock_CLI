  "author": "",
  "license": "MIT",
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^11.1.0",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "node-fetch": "^2.7.0",
    "openapi-types": "^12.1.3",
    "uuid": "^9.0.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.9",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.2"
  }
